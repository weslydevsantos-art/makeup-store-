# ===========================================
# CONFIGURACAO DO BANCO DE DADOS (Supabase)
# ===========================================
# Obtenha essas URLs no painel do Supabase:
# Project Settings > Database > Connection string

# Connection string com pooling (porta 6543) - usar na aplicacao
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connection string direta (porta 5432) - usar apenas para migracoes
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ===========================================
# CONFIGURACAO DO GATEWAY DE PAGAMENTO (UniPay)
# ===========================================
# Obtenha suas credenciais no painel da UniPay: https://unipaybr.com

# Chave de API da UniPay
UNIPAY_API_KEY="sua-chave-api-unipay"

# ID do merchant na UniPay (se aplicavel)
UNIPAY_MERCHANT_ID="seu-merchant-id"

# ===========================================
# CONFIGURACAO DO ADMIN
# ===========================================

# Senha para acessar o painel administrativo
ADMIN_PASSWORD="ana123456"

# ===========================================
# CONFIGURACAO DA APLICACAO
# ===========================================

# URL publica da aplicacao (usada para callbacks e webhooks)
NEXT_PUBLIC_APP_URL="https://anamake.vercel.app"
